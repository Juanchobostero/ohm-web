---
import { clients } from '../data/content';
---
<section id="clients">
  <div class="container">
    <div class="reveal">
      <div class="section-tag">Nuestros clientes</div>
      <h2 class="section-title">Empresas que<br><em>confían</em> en nosotros</h2>
    </div>
    <div class="clients-grid reveal">
      {clients.map(c => (
        <div class="client-card">
          {c.logo
            ? <img src={c.logo} alt={c.name} class="client-logo" />
            : (
              <div class="client-logo-placeholder">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <rect x="2" y="7" width="20" height="14" rx="2"/>
                  <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                </svg>
              </div>
            )
          }
          <div class="client-name">{c.name}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #clients {
    background-color: var(--black-2);
    background-image: var(--dots-dim);
    background-size: var(--dots-size);
    padding: 7rem var(--pad-x);
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5px;
    background: rgba(212,160,23,0.1);
    margin-top: 3.5rem;
  }

  .client-card {
    background: var(--black-3);
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.2rem;
    transition: background 0.3s;
    position: relative;
    overflow: hidden;
  }
  .client-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 100%;
    height: 2px;
    background: var(--gold);
    transition: right 0.4s ease;
  }
  .client-card:hover { background: var(--black-4); }
  .client-card:hover::after { right: 0; }

  .client-logo {
    width: 80px; height: 80px;
    object-fit: contain;
  }

  .client-logo-placeholder {
    width: 80px; height: 80px;
    border: 1px solid rgba(212,160,23,0.15);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(212,160,23,0.25);
  }

  .client-name {
    font-family: var(--condensed);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--white-dim);
    text-align: center;
  }
</style>
