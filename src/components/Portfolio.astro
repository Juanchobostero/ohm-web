---
import { portfolio } from '../data/content';
---
<section id="portfolio">
  <div class="container">
    <div class="portfolio-header reveal">
      <div>
        <div class="section-tag">Proyectos</div>
        <h2 class="section-title">Trabajos<br><em>realizados</em></h2>
      </div>
      <a href="#contact" class="btn-secondary">Ver todos →</a>
    </div>

    <div class="portfolio-grid reveal">
      {portfolio.map(p => (
        <div class={`portfolio-item${p.featured ? ' featured' : ''}`}>
          {p.image
            ? <img src={p.image} alt={p.title} loading="lazy" />
            : (
              <div class="portfolio-placeholder">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <rect x="3" y="3" width="18" height="18" rx="1"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
                <span>Foto proyecto</span>
              </div>
            )
          }
          <div class="portfolio-overlay">
            <h4>{p.title}</h4>
            <p>{p.category} · {p.year}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #portfolio {
    background-color: var(--black-2);
    background-image: var(--dots-dim);
    background-size: var(--dots-size);
    padding: 7rem var(--pad-x);
  }

  .portfolio-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 2px;
  }

  .portfolio-item {
    background: var(--black-3);
    aspect-ratio: 4/3;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }
  .portfolio-item.featured {
    grid-row: span 2;
    aspect-ratio: unset;
  }
  .portfolio-item img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  .portfolio-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--black-3) 0%, var(--black-4) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    border: 1px solid rgba(212,160,23,0.06);
  }
  .portfolio-placeholder svg {
    color: rgba(212,160,23,0.2);
    width: 40px; height: 40px;
  }
  .portfolio-placeholder span {
    font-family: var(--condensed);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(212,160,23,0.3);
  }

  .portfolio-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8,8,8,0.9) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
  }
  .portfolio-item:hover .portfolio-overlay { opacity: 1; }

  .portfolio-overlay h4 {
    font-family: var(--serif);
    font-size: 1.2rem;
    color: var(--white);
  }
  .portfolio-overlay p {
    font-family: var(--condensed);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 0.3rem;
  }
</style>
