---
import { portfolio } from '../data/content';

// Estado para controlar cuántos proyectos mostrar
const initialProjects = 4;
const showAll = Astro.url.searchParams.get('showAll') === 'true';
const visibleProjects = showAll ? portfolio : portfolio.slice(0, initialProjects);
---

<section id="portfolio">
  <div class="container">
    <div class="portfolio-header reveal">
      <div>
        <div class="section-tag">Proyectos</div>
        <h2 class="section-title">Algunos trabajos<br><em>realizados</em></h2>
      </div>
    </div>

    <div class="portfolio-grid reveal">
      {visibleProjects.map(p => (
        <div class={`portfolio-item${p.featured ? ' featured' : ''}`} data-project-id={p.id}>
          {p.image
            ? <img src={p.image} alt={p.title} loading="lazy" />
            : (
              <div class="portfolio-placeholder">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <rect x="3" y="3" width="18" height="18" rx="1"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
                <span>Foto proyecto</span>
              </div>
            )
          }
          <div class="portfolio-overlay">
            <h4>{p.title}</h4>
            <p>{p.category} · {p.year}</p>
          </div>
        </div>
      ))}
    </div>

    {showAll && (
      <div style={{textAlign: 'center', marginTop: '3rem'}}>
        <a href="#portfolio" class="btn-secondary">Mostrar menos</a>
      </div>
    )}
  </div>
</section>

<div id="projectModal" class="modal">
  <div class="modal-content">
    <button class="modal-close" id="modalCloseBtn">×</button>
    <button class="modal-prev" id="modalPrevBtn">‹</button>
    <button class="modal-next" id="modalNextBtn">›</button>
    
    <div class="modal-image-container">
      <img id="modalImage" src="" alt="" />
    </div>
    
    <div class="modal-info">
      <h3 id="modalTitle"></h3>
      <p id="modalDesc"></p>
      <div id="imageCounter" class="image-counter"></div>
    </div>
  </div>
</div>

<script define:vars={{ portfolio }}>
  // Modal functionality
  let modalInstance = null;
  let currentImageIndex = 0;
  let currentProjectImages = [];
  let currentProject = null;

  function openProjectModal(projectId) {
    const project = portfolio.find(p => p.id === projectId);
    if (!project) return;

    currentProject = project;
    currentProjectImages = project.images && project.images.length > 0 
      ? project.images 
      : [project.image];
    currentImageIndex = 0;
    
    const modalImg = document.getElementById('modalImage');
    const modalTitle = document.getElementById('modalTitle');
    const modalDesc = document.getElementById('modalDesc');
    const counter = document.getElementById('imageCounter');
    
    if (modalImg && currentProjectImages[0]) {
      modalImg.src = currentProjectImages[currentImageIndex];
      modalImg.alt = project.title;
    }
    if (modalTitle) modalTitle.textContent = project.title;
    if (modalDesc) modalDesc.textContent = `${project.category} · ${project.year}`;
    if (counter) {
      counter.textContent = currentProjectImages.length > 1 
        ? `${currentImageIndex + 1} / ${currentProjectImages.length}` 
        : '';
    }
    
    const prevBtn = document.getElementById('modalPrevBtn');
    const nextBtn = document.getElementById('modalNextBtn');
    if (prevBtn && nextBtn) {
      const hasMultipleImages = currentProjectImages.length > 1;
      prevBtn.style.display = hasMultipleImages ? 'flex' : 'none';
      nextBtn.style.display = hasMultipleImages ? 'flex' : 'none';
    }
    
    modalInstance.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modalInstance.classList.remove('active');
    document.body.style.overflow = '';
  }

  function nextImage() {
    if (currentImageIndex < currentProjectImages.length - 1) {
      currentImageIndex++;
      updateModalImage();
    }
  }

  function prevImage() {
    if (currentImageIndex > 0) {
      currentImageIndex--;
      updateModalImage();
    }
  }

  function updateModalImage() {
    const modalImg = document.getElementById('modalImage');
    const counter = document.getElementById('imageCounter');
    if (modalImg && currentProjectImages[currentImageIndex]) {
      modalImg.src = currentProjectImages[currentImageIndex];
    }
    if (counter && currentProjectImages.length > 1) {
      counter.textContent = `${currentImageIndex + 1} / ${currentProjectImages.length}`;
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    modalInstance = document.getElementById('projectModal');
    
    document.querySelectorAll('.portfolio-item').forEach(item => {
      item.addEventListener('click', (e) => {
        if (e.target.closest('.btn-secondary')) return;
        const projectId = parseInt(item.dataset.projectId);
        if (projectId) {
          openProjectModal(projectId);
        }
      });
    });
    
    const closeBtn = document.getElementById('modalCloseBtn');
    const prevBtn = document.getElementById('modalPrevBtn');
    const nextBtn = document.getElementById('modalNextBtn');
    
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (prevBtn) prevBtn.addEventListener('click', prevImage);
    if (nextBtn) nextBtn.addEventListener('click', nextImage);
    
    if (modalInstance) {
      modalInstance.addEventListener('click', (e) => {
        if (e.target === modalInstance) {
          closeModal();
        }
      });
    }
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modalInstance && modalInstance.classList.contains('active')) {
        closeModal();
      }
    });
  });
</script>

<style>
  #portfolio {
    background-color: var(--black-2);
    background-image: var(--dots-dim);
    background-size: var(--dots-size);
    padding: 7rem var(--pad-x);
  }

  .portfolio-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 2px;
  }

  .portfolio-item {
    background: var(--black-3);
    aspect-ratio: 4/3;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.3s ease;
  }
  
  .portfolio-item:hover {
    transform: scale(1.02);
    z-index: 1;
  }
  
  .portfolio-item.featured {
    grid-row: span 2;
    aspect-ratio: unset;
  }
  
  .portfolio-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  
  .portfolio-item:hover img {
    transform: scale(1.05);
  }

  .portfolio-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--black-3) 0%, var(--black-4) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    border: 1px solid rgba(212,160,23,0.06);
  }
  
  .portfolio-placeholder svg {
    color: rgba(212,160,23,0.2);
    width: 40px;
    height: 40px;
  }
  
  .portfolio-placeholder span {
    font-family: var(--condensed);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(212,160,23,0.3);
  }

  .portfolio-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8,8,8,0.95) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
  }
  
  .portfolio-item:hover .portfolio-overlay { 
    opacity: 1; 
  }

  .portfolio-overlay h4 {
    font-family: var(--serif);
    font-size: 1.2rem;
    color: var(--white);
    margin: 0;
    transform: translateY(20px);
    transition: transform 0.3s ease;
  }
  
  .portfolio-item:hover .portfolio-overlay h4 {
    transform: translateY(0);
  }
  
  .portfolio-overlay p {
    font-family: var(--condensed);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 0.3rem;
    transform: translateY(20px);
    transition: transform 0.3s ease 0.05s;
  }
  
  .portfolio-item:hover .portfolio-overlay p {
    transform: translateY(0);
  }

  /* MODAL CORREGIDO */
  .modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.95);
    z-index: 1000;
    justify-content: center;
    align-items: center;
    backdrop-filter: blur(5px);
  }
  
  .modal.active {
    display: flex;
    animation: fadeIn 0.3s ease;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  .modal-content {
    position: relative;
    max-width: 85vw;
    max-height: 85vh;
    background: var(--black-2);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    display: flex;
    flex-direction: column;
  }
  
  .modal-image-container {
    width: 100%;
    height: auto;
    max-height: 65vh;
    overflow: hidden;
    background: var(--black-3);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .modal-image-container img {
    max-width: 100%;
    max-height: 65vh;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    animation: zoomIn 0.3s ease;
  }
  
  @keyframes zoomIn {
    from { transform: scale(0.95); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }
  
  .modal-info {
    padding: 1.5rem;
    background: var(--black-3);
    color: var(--white);
    border-top: 1px solid rgba(212,160,23,0.1);
  }
  
  .modal-info h3 {
    font-family: var(--serif);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--white);
  }
  
  .modal-info p {
    font-family: var(--condensed);
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8rem;
  }
  
  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(0,0,0,0.7);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    font-size: 2rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }
  
  .modal-close:hover {
    background: rgba(212,160,23,0.8);
    transform: scale(1.05);
  }
  
  .modal-prev,
  .modal-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0,0,0,0.7);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    font-size: 3rem;
    padding: 0.5rem 1rem;
    cursor: pointer;
    z-index: 10;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .modal-prev:hover,
  .modal-next:hover {
    background: rgba(212,160,23,0.8);
    transform: translateY(-50%) scale(1.05);
  }
  
  .modal-prev { 
    left: 1rem; 
    border-radius: 0 8px 8px 0;
  }
  
  .modal-next { 
    right: 1rem;
    border-radius: 8px 0 0 8px;
  }
  
  .image-counter {
    margin-top: 0.8rem;
    font-size: 0.8rem;
    color: var(--gray);
    text-align: center;
    font-family: var(--condensed);
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    #portfolio {
      padding: 4rem var(--pad-x);
    }

    .portfolio-header {
      flex-direction: column;
      gap: 2rem;
      align-items: flex-start;
      margin-bottom: 2rem;
    }

    .portfolio-header a {
      width: 100%;
      text-align: center;
      padding: 0.7rem 1.2rem;
      font-size: 0.7rem;
    }

    .portfolio-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      gap: 1px;
    }

    .portfolio-item {
      aspect-ratio: 4/3;
    }

    .portfolio-item.featured {
      grid-row: unset;
      aspect-ratio: 4/3;
    }

    .portfolio-overlay h4 {
      font-size: 1rem;
    }

    .portfolio-overlay p {
      font-size: 0.6rem;
    }
    
    .modal-content {
      max-width: 95vw;
      max-height: 90vh;
    }
    
    .modal-image-container {
      max-height: 60vh;
    }
    
    .modal-image-container img {
      max-height: 60vh;
    }
    
    .modal-prev,
    .modal-next {
      font-size: 2rem;
      padding: 0.3rem 0.8rem;
    }
    
    .modal-info h3 {
      font-size: 1.2rem;
    }
    
    .modal-info p {
      font-size: 0.7rem;
    }
    
    .modal-close {
      width: 35px;
      height: 35px;
      font-size: 1.5rem;
      top: 0.5rem;
      right: 0.5rem;
    }
  }

  /* MODAL CORREGIDO - TAMAÑO FIJO */
.modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.95);
  z-index: 1000;
  justify-content: center;
  align-items: center;
  backdrop-filter: blur(5px);
}

.modal.active {
  display: flex;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  position: relative;
  width: 85vw;
  height: 85vh;  /* Altura fija en lugar de max-height */
  background: var(--black-2);
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  display: flex;
  flex-direction: column;
}

.modal-image-container {
  width: 100%;
  height: calc(85vh - 120px);  /* Altura fija restando el espacio de la info */
  overflow: hidden;
  background: var(--black-3);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.modal-image-container img {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;  /* Mantiene la proporción sin recortar */
  display: block;
  animation: zoomIn 0.3s ease;
}

@keyframes zoomIn {
  from { transform: scale(0.95); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.modal-info {
  padding: 1.5rem;
  background: var(--black-3);
  color: var(--white);
  border-top: 1px solid rgba(212,160,23,0.1);
  height: 120px;  /* Altura fija para la info */
  box-sizing: border-box;
}

@media (max-width: 768px) {
  .modal-content {
    width: 95vw;
    height: 90vh;
  }
  
  .modal-image-container {
    height: calc(90vh - 100px);
  }
  
  .modal-info {
    height: 100px;
    padding: 1rem;
  }
  
  .modal-info h3 {
    font-size: 1.2rem;
  }
  
  .modal-info p {
    font-size: 0.7rem;
  }
}

.modal-image-container {
  width: 100%;
  aspect-ratio: 16 / 9;  /* Proporción fija como una pantalla de cine */
  background: var(--black-3);
  display: flex;
  align-items: center;
  justify-content: center;
}

  @media (max-width: 1024px) and (min-width: 769px) {
    .portfolio-grid {
      grid-template-columns: 1fr 1fr;
    }

    .portfolio-item.featured {
      grid-row: span 1;
      grid-column: span 1;
    }
  }
</style>