---
import { site, contact } from '../data/content';
---
<section id="contact">
  <div class="container contact-inner">
    <div class="contact-left reveal">
      <div class="section-tag">Hablemos</div>
      <h2 class="section-title">¿Tenés un<br><em>proyecto</em>?</h2>
      <p>Estamos listos para asesorarte y presupuestar tu instalación eléctrica. Respondemos en menos de 24 horas.</p>

      <div class="contact-channels">
        <!-- WhatsApp -->
        <a href={`https://wa.me/${site.whatsapp.replace(/\D/g, '')}`} class="contact-btn" target="_blank" rel="noopener">
          <svg class="cb-icon" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <div>
            <span class="cb-text">WhatsApp</span>
            <span class="cb-sub">Respuesta inmediata</span>
          </div>
          <svg class="cb-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>

        <!-- Google Form -->
        <a href={site.googleForm} class="contact-btn" target="_blank" rel="noopener">
          <svg class="cb-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <line x1="3" y1="9" x2="21" y2="9"/>
            <polyline points="9 21 9 9"/>
          </svg>
          <div>
            <span class="cb-text">Formulario de contacto</span>
            <span class="cb-sub">Contanos tu proyecto</span>
          </div>
          <svg class="cb-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>

        <!-- Email -->
        <a href={`mailto:${site.email}`} class="contact-btn">
          <svg class="cb-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <polyline points="2,4 12,13 22,4"/>
          </svg>
          <div>
            <span class="cb-text">Email</span>
            <span class="cb-sub">{site.email}</span>
          </div>
          <svg class="cb-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="contact-right reveal">
      <div class="contact-info-block">
        <div>
          <div class="ci-label">Ubicación</div>
          <div class="ci-value">{contact.location}</div>
        </div>
        <div>
          <div class="ci-label">Cobertura</div>
          <div class="ci-value">{contact.coverage}</div>
        </div>
        <div>
          <div class="ci-label">Horario</div>
          <div class="ci-value">{contact.schedule}</div>
        </div>
        <div>
          <div class="ci-label">Especialización</div>
          <div class="ci-value">{contact.specialization}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #contact {
    background-color: var(--black-2);
    background-image: var(--dots-dim);
    background-size: var(--dots-size);
    position: relative;
    overflow: hidden;
    padding: 7rem var(--pad-x);
  }
  #contact::before {
    content: 'OHM';
    position: absolute;
    bottom: -2rem; right: -1rem;
    font-family: var(--hero-serif);
    font-size: 20rem;
    font-weight: 700;
    color: rgba(212,160,23,0.02);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
    position: relative;
    z-index: 1;
  }

  .contact-left p {
    font-size: 1rem;
    font-weight: 300;
    color: var(--white-dim);
    line-height: 1.8;
    margin-top: 1.5rem;
    max-width: 420px;
  }

  .contact-channels {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .contact-btn {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.8rem;
    border: 1px solid rgba(212,160,23,0.2);
    background: transparent;
    text-decoration: none;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
  }
  .contact-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--gold);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    z-index: 0;
  }
  .contact-btn:hover::before { transform: translateX(0); }
  .contact-btn:hover .cb-icon,
  .contact-btn:hover .cb-text,
  .contact-btn:hover .cb-sub,
  .contact-btn:hover .cb-arrow { color: var(--black) !important; }

  .cb-icon  { color: var(--gold); flex-shrink: 0; position: relative; z-index: 1; transition: color 0.25s; }
  .cb-text  { font-family: var(--condensed); font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--white); position: relative; z-index: 1; transition: color 0.25s; }
  .cb-sub   { font-size: 0.7rem; color: var(--white-dim); font-family: var(--sans); display: block; margin-top: 0.1rem; transition: color 0.25s; }
  .cb-arrow { margin-left: auto; color: var(--gold-dim); position: relative; z-index: 1; transition: color 0.25s; }

  .contact-right { padding-top: 0.5rem; }

  .contact-info-block {
    border-left: 1px solid rgba(212,160,23,0.2);
    padding-left: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .ci-label {
    font-family: var(--condensed);
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.4rem;
  }
  .ci-value { font-size: 1rem; color: var(--white-dim); font-weight: 300; }
</style>
