---
import { services } from '../data/content';
---
<section id="services">
  <div class="container">
    <div class="services-header reveal">
      <div class="section-tag">Lo que hacemos</div>
      <h2 class="section-title">Nuestros<br><em>servicios</em></h2>
    </div>
    <div class="services-grid reveal">
      {services.map(s => (
        <div class="service-card">
          <span class="service-num">{s.num}</span>
          <h3 class="service-name">{s.name}</h3>
          <p class="service-desc">{s.desc}</p>
          <div class="service-detail">
            {s.items.map(item => <span>{item}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #services {
    background-color: var(--black);
    background-image: var(--dots);
    background-size: var(--dots-size);
    padding: 7rem var(--pad-x);
  }

  .services-header { margin-bottom: 4rem; }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: rgba(212,160,23,0.1);
  }

  .service-card {
    background: var(--black-2);
    padding: 3rem 2.5rem;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }
  .service-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 100%;
    height: 2px;
    background: var(--gold);
    transition: right 0.4s ease;
  }
  .service-card:hover { background: var(--black-3); }
  .service-card:hover::after { right: 0; }

  .service-num {
    font-family: var(--hero-serif);
    font-size: 3.5rem;
    font-weight: 700;
    color: rgba(212,160,23,0.08);
    position: absolute;
    top: 1.5rem; right: 2rem;
    line-height: 1;
    pointer-events: none;
    transition: color 0.3s;
  }
  .service-card:hover .service-num { color: rgba(212,160,23,0.15); }

  .service-name {
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--white);
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .service-desc {
    font-size: 0.88rem;
    font-weight: 300;
    color: var(--white-dim);
    line-height: 1.7;
  }

  .service-detail {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .service-detail span {
    font-family: var(--condensed);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold-dim);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .service-detail span::before {
    content: '—';
    color: var(--gold);
    font-size: 0.6rem;
  }

  /* ─── MOBILE ─── */
  @media (max-width: 768px) {
    #services {
      padding: 4rem var(--pad-x);
    }

    .services-header {
      margin-bottom: 2rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
      gap: 1px;
    }

    .service-card {
      padding: 2rem 1.5rem;
    }

    .service-num {
      font-size: 2.5rem;
      top: 0.8rem;
      right: 1rem;
      opacity: 0.6;
    }

    .service-name {
      font-size: 1.3rem;
    }

    .service-desc {
      font-size: 0.8rem;
    }
  }

  @media (max-width: 1024px) and (min-width: 769px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
