---
import { site } from '../data/content';
---
<section id="hero">
  <div class="hero-bg"></div>
  <div class="circuit-lines" aria-hidden="true">
    <svg viewBox="0 0 400 800" fill="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="50" y1="0" x2="50" y2="800" stroke="#D4A017" stroke-width="0.5"/>
      <line x1="150" y1="0" x2="150" y2="300" stroke="#D4A017" stroke-width="0.5"/>
      <line x1="150" y1="300" x2="250" y2="300" stroke="#D4A017" stroke-width="0.5"/>
      <line x1="250" y1="300" x2="250" y2="800" stroke="#D4A017" stroke-width="0.5"/>
      <line x1="350" y1="100" x2="350" y2="500" stroke="#D4A017" stroke-width="0.5"/>
      <line x1="350" y1="100" x2="400" y2="100" stroke="#D4A017" stroke-width="0.5"/>
      <circle cx="150" cy="300" r="4" fill="#D4A017"/>
      <circle cx="250" cy="300" r="4" fill="#D4A017"/>
      <circle cx="50" cy="200" r="3" fill="#D4A017"/>
      <circle cx="350" cy="100" r="3" fill="#D4A017"/>
      <circle cx="350" cy="500" r="3" fill="#D4A017"/>
      <line x1="0" y1="500" x2="350" y2="500" stroke="#D4A017" stroke-width="0.5" stroke-dasharray="4 8"/>
      <rect x="140" y="380" width="20" height="12" stroke="#D4A017" stroke-width="0.5" rx="1"/>
      <rect x="240" y="180" width="20" height="12" stroke="#D4A017" stroke-width="0.5" rx="1"/>
    </svg>
  </div>

  <div class="hero-content container">
    <div class="hero-eyebrow">{site.tagline}</div>
    <h1 class="hero-title">
      <span class="ohm-gold">ΩHM</span>
      <span class="hero-sub">Electromecánica</span>
    </h1>
    <p class="hero-desc">
      Soluciones en <strong>instalaciones eléctricas industriales y comerciales</strong> para las
      empresas más exigentes de la región. Precisión, seguridad y tecnología de vanguardia.
    </p>
    <div class="hero-actions">
      <a href="#portfolio" class="btn-primary">Ver proyectos</a>
      <a href="#contact" class="btn-secondary">Contactar</a>
    </div>
  </div>

  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 8rem var(--pad-x) 4rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 60% at 70% 50%, rgba(212,160,23,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 40% 80% at 10% 80%, rgba(212,160,23,0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  .circuit-lines {
    position: absolute;
    right: 0; top: 0; bottom: 0;
    width: 45%;
    opacity: 0.07;
    overflow: hidden;
    pointer-events: none;
  }
  .circuit-lines svg { width: 100%; height: 100%; }

  .hero-content { position: relative; z-index: 1; }

  .hero-eyebrow {
    font-family: var(--condensed);
    font-size: 0.7rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.2s forwards;
  }
  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 40px; height: 1px;
    background: var(--gold);
  }

  .hero-title {
    font-family: var(--hero-serif);
    font-size: clamp(5rem, 13vw, 12rem);
    font-weight: 700;
    line-height: 0.85;
    letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.4s forwards;
  }

  .ohm-gold {
    display: block;
    background: linear-gradient(
      135deg,
      #8B6000 0%, #C8920A 12%, #F0C040 22%, #FDE272 30%,
      #D4A017 38%, #A07810 45%, #F5D060 52%, #FDE272 58%,
      #C8920A 66%, #8B6000 75%, #D4A017 84%, #F0C040 92%, #C8920A 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 2px 12px rgba(212,160,23,0.35));
    position: relative;
  }
  .ohm-gold::after {
    content: 'ΩHM';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%, rgba(255,240,150,0.55) 48%,
      rgba(255,255,220,0.7) 52%, transparent 70%
    );
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: goldShimmer 3.5s ease-in-out infinite;
  }

  .hero-sub {
    display: block;
    font-family: var(--condensed);
    font-size: clamp(0.9rem, 2vw, 1.3rem);
    font-weight: 400;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--white-dim);
    margin-top: 0.6rem;
    -webkit-text-fill-color: var(--white-dim);
  }

  .hero-desc {
    font-size: 1rem;
    font-weight: 300;
    color: var(--white-dim);
    max-width: 480px;
    line-height: 1.7;
    margin-top: 1.5rem;
    margin-bottom: 3rem;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.7s forwards;
  }
  .hero-desc strong { color: var(--white); font-weight: 500; }

  .hero-actions {
    display: flex;
    gap: 1rem;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.85s forwards;
  }

  .scroll-indicator {
    position: absolute;
    right: var(--pad-x);
    bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeIn 1s ease 1.5s forwards;
  }
  .scroll-indicator span {
    font-family: var(--condensed);
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--white-dim);
    writing-mode: vertical-rl;
  }
  .scroll-line {
    width: 1px; height: 50px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s ease infinite;
  }
</style>
